<notes-rules type="config" xmlns:xi="http://www.w3.org/2001/XInclude">
  
    <name>Geonovum UGM</name>
    
    <!--
        De taal waarin notes fields intern worden omgezet. 
        Beste is gewoon markdown of plain aan te houden.
    -->
    <notes-format>markdown</notes-format>
    
    <!--
        is het toegestaan om in notes fields náást HTML constructies ook markdown op te memen? 
    -->
    <notes-format-allow-markdown>no</notes-format-allow-markdown>
    
    <notes-rule lang="nl" default="Definitie">
        <section title="Definitie" tagged-value="CFG-TV-DEFINITION">
            <!-- no labels -->
        </section>
        <section title="Omschrijving" tagged-value="CFG-TV-DESCRIPTION">
            <!-- no labels -->
        </section>
        <section title="Patroon" tagged-value="CFG-TV-FORMALPATTERN">
            <!-- no labels -->
        </section>
    </notes-rule>
    
</notes-rules>